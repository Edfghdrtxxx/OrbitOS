# Obsidian - track core settings, ignore workspace/cache
.obsidian/*
!.obsidian/app.json
!.obsidian/appearance.json
!.obsidian/community-plugins.json
!.obsidian/core-plugins.json
!.obsidian/graph.json

# Obsidian system
.trash/

# Tool configs - ignore local/temp only
.claude/settings.local.json
.gemini/tmp/

# System junk
.DS_Store
Thumbs.db
*.tmp
*~
*.log

# Sensitive personal data
100_Memoranda/
50_Resources/EmailMessages/

# Large binaries and build artifacts
20_Project/AstrBot/*
!20_Project/AstrBot/AstrBot.md
20_Project/Bilibili-RAG/*
!20_Project/Bilibili-RAG/Bilibili-RAG.md

# Large Resources can be found in Internet.
50_Resources/Physics/literature/

# Uncompatible files
50_Resources/Physics/Courseware/*

# Externally-cloned skills (maintained via their own git)
.agents/skills/web-access/
