{
	"nodes":[
		{"id":"central","type":"text","text":"# Prof. Nobuaki Imai\n**Associate Professor — CNS, University of Tokyo**\nScientific coordinator, OEDO-SHARAQ beamline\n~288 publications, 4,461+ citations\n[[Nobuaki_Imai_Research_Program]]","x":700,"y":440,"width":340,"height":200,"color":"6"},
